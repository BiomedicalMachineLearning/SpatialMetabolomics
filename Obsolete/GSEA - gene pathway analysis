library(Seurat)
library(ggplot2)
library(dplyr)
library(stringr)
library(hdf5r)
library(ggpubr)
library(patchwork)
library(viridis)
library(clusterProfiler)
library(enrichplot)
library(DOSE)

# SET THE DESIRED ORGANISM HERE
organism = "org.Hs.eg.db"
BiocManager::install(organism, character.only = TRUE)
library(organism, character.only = TRUE)

# reading in data from deseq2
df <- read.csv("/QRISdata/Q1851/Hani/SpatialMetabolomics/Significant_genes.csv")
head(df)
unique(df$regulate)

# we want the log2 fold change 
original_gene_list <- df$logFC

# name the vector
names(original_gene_list) <- df$gene

# omit any NA values 
gene_list<-na.omit(original_gene_list)

# sort the list in decreasing order (required for clusterProfiler)
gene_list = sort(gene_list, decreasing = TRUE)

# GSEA analysis
keytypes(org.Hs.eg.db)
gse <- gseGO(geneList=gene_list, OrgDb = organism, keyType = "SYMBOL")

# pairwise term similarity 
gse2 <- pairwise_termsim(gse)

# plotting
require(DOSE)
options(repr.plot.width = 10, repr.plot.height = 10)
dotplot(gse, showCategory=10, split=".sign") + facet_grid(.~.sign)

emapplot(gse2)

emapplot_cluster(gse2)

ridgeplot(gse) + labs(x = "enrichmentScore")

#####################################################################################

# only using up/down regulated genes 
sig <- subset(df, subset = regulate %in% c("Up", "Down"))

# sort the list in decreasing order (required for clusterProfiler)
original_gene_list <- sig$logFC
names(original_gene_list) <- sig$gene
gene_list <-na.omit(original_gene_list)
gene_list = sort(gene_list, decreasing = TRUE)

# GSEA analysis
gse_comb <- gseGO(geneList=gene_list, 
                OrgDb = organism, 
                keyType = "SYMBOL",
                ont = "BP",
                nPermSimple = 10000,
               )

# plotting for combined (up/down) GSEA results
require(DOSE)
options(repr.plot.width = 10, repr.plot.height = 10)
dot_plot <- dotplot(gse_comb, showCategory=10, split=".sign") + facet_grid(.~.sign)
dot_plot
ggsave(dot_plot, filename = "/QRISdata/Q1851/Hani/SpatialMetabolomics/GSEA/dot_plot.pdf", height = 10, width = 10)

# split to show up regulated only
gse_up <- gse_comb
gse_up@result <- gse_up[gse_up$enrichmentScore > 0,]

# split to show down regulated only
gse_down <- gse_comb
gse_down@result <- gse_down[gse_down$enrichmentScore < 0,]

# pairwise term similarity 
gse_comb2 <- pairwise_termsim(gse_comb)
gse_up2 <- pairwise_termsim(gse_up)
gse_down2 <- pairwise_termsim(gse_down)

# plotting 
comb_clust <- emapplot_cluster(gse_comb2)
comb_clust

up_clust <- emapplot_cluster(gse_up2)
up_clust

down_clust <- emapplot_cluster(gse_down2)
down_clust
 
ggsave(comb_clust, filename = "/QRISdata/Q1851/Hani/SpatialMetabolomics/GSEA/comb_clust.pdf", height = 10, width = 10)
ggsave(up_clust, filename = "/QRISdata/Q1851/Hani/SpatialMetabolomics/GSEA/up_clust.pdf", height = 10, width = 10)
ggsave(down_clust, filename = "/QRISdata/Q1851/Hani/SpatialMetabolomics/GSEA/down_clust.pdf", height = 10, width = 10)

